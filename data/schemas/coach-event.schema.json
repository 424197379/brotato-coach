{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.brotato-coach/schemas/coach-event.schema.json",
  "title": "CoachEvent",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "sequence",
    "captured_at_utc",
    "event_type",
    "player_index",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "captured_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "game_version": {
      "type": "string"
    },
    "recorder_version": {
      "type": "string"
    },
    "rule_pack_version": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "run_started",
        "wave_started",
        "wave_completed",
        "shop_observed",
        "coach_requested",
        "wave_retried",
        "run_ended"
      ]
    },
    "player_index": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
