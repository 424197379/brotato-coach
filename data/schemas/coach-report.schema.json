{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.brotato-coach/schemas/coach-report.schema.json",
  "title": "CoachReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "snapshot_fingerprint",
    "rule_pack_version",
    "summary",
    "shop_advice",
    "stat_diagnosis",
    "plans",
    "run_review",
    "warnings",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "report_id": {
      "type": "string"
    },
    "snapshot_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "rule_pack_version": {
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "shop_advice": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shop_action"
      }
    },
    "reroll_advice": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "stat_diagnosis": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stat_gap"
      }
    },
    "plans": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave_plus_3",
        "wave_plus_5"
      ],
      "properties": {
        "wave_plus_3": {
          "$ref": "#/$defs/plan"
        },
        "wave_plus_5": {
          "$ref": "#/$defs/plan"
        }
      }
    },
    "run_review": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/review_finding"
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_key",
        "severity"
      ],
      "properties": {
        "message_key": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "rule_id": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "evidence"
      ],
      "properties": {
        "rule_id": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "shop_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "action",
        "rank",
        "price",
        "reasons",
        "tradeoffs",
        "confidence"
      ],
      "properties": {
        "item_id": {
          "type": "string"
        },
        "action": {
          "enum": [
            "buy_now",
            "lock",
            "defer",
            "skip"
          ]
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "price": {
          "type": "integer",
          "minimum": 0
        },
        "reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reason"
          }
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tradeoffs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reason"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "stat_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stat_id",
        "current",
        "target",
        "deadline_wave",
        "severity",
        "dimensions",
        "rule_id",
        "evidence"
      ],
      "properties": {
        "stat_id": {
          "type": "string"
        },
        "current": {
          "type": "number"
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {"type": "number"},
            "max": {"type": "number"},
            "target": {"type": "number"},
            "tolerance": {"type": "number"}
          }
        },
        "deadline_wave": {
          "type": "integer",
          "minimum": 1
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rule_id": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "deadline_wave",
        "targets",
        "priorities",
        "avoid",
        "fallback"
      ],
      "properties": {
        "deadline_wave": {
          "type": "integer",
          "minimum": 1
        },
        "targets": {
          "type": "object",
          "additionalProperties": true
        },
        "priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "review_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "first_observed_wave",
        "direct_or_root_cause",
        "severity",
        "evidence",
        "counterfactual",
        "next_run_rule"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "first_observed_wave": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "direct_or_root_cause": {
          "enum": [
            "direct",
            "root",
            "contributing",
            "positive"
          ]
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true
        },
        "counterfactual": {
          "type": "string"
        },
        "next_run_rule": {
          "type": "string"
        }
      }
    }
  }
}
